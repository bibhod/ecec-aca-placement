# ─── Copy this to .env and fill in your values ──────────────────────────────
# Run with: docker-compose up --build

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=ecec
POSTGRES_PASSWORD=ecec_secret_change_me
POSTGRES_DB=ecec_placement

# ── JWT Auth — CHANGE to a random 32+ character string in production ──────────
SECRET_KEY=change-me-to-a-random-32-character-string-in-production

# ── Email — Option A: SendGrid (recommended) ──────────────────────────────────
# Sign up at https://sendgrid.com — free tier: 100 emails/day
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
USE_SMTP=false

# ── Email — Option B: SMTP (Gmail, Outlook, etc.) ─────────────────────────────
# USE_SMTP=true
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password   # Use Gmail App Password, not your account password

# ── Email sender identity ─────────────────────────────────────────────────────
FROM_EMAIL=noreply@academies.edu.au
FROM_NAME=Academies Australasia

# ── SMS — Twilio (Issue 2 / 15 / 16) ─────────────────────────────────────────
# Sign up at https://www.twilio.com — free trial includes test credits
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# TWILIO_FROM_NUMBER=+61400000000       # Your Twilio phone number (E.164 format)

# ── Google Maps API (Issue 7 — address autocomplete in Add Centre) ────────────
# Enable "Places API" and "Maps JavaScript API" in Google Cloud Console
# https://console.cloud.google.com/apis/library
# GOOGLE_MAPS_API_KEY=AIzaSy_your_google_maps_api_key_here

# ── Frontend URL (used in email links) ───────────────────────────────────────
FRONTEND_URL=http://localhost:80
